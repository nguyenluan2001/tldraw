# =============================================================================
# Tldraw Snapshots - Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values as needed.
# These values are used by both the server and client applications.
# =============================================================================

# Server URL (full URL including protocol, host and port)
# Example: http://localhost:3002, http://192.168.1.100:3002, https://api.example.com
SERVER_URL=http://localhost:3002

# Client Configuration (Vite)
# The port for the frontend development server
VITE_PORT=5173
